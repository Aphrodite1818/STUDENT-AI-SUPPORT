#======================================#
#              .env.example            #
#======================================#


#--- App ---#
ENV=dev
# Leave LOG_LEVEL unset for normal defaults: dev=DEBUG, prod/stg=INFO
# Set LOG_LEVEL only when you intentionally need an override.
# LOG_LEVEL=INFO
APP_NAME="School Management System"
API_V1_PREFIX=/api/v1


#--- Security ---#
# generate with: openssl rand -hex 64
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60


#--- Database ---#
# ENV=dev uses a hardcoded local asyncpg URL from app/config/settings.py
# Set DATABASE_URL only for non-dev environments.
DATABASE_URL=


#--- CORS ---#
# JSON array format
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8501"]


#--- Gemini ---#
# get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

LLM_MAX_TOKENS=1024


#--- Twilio ---#
# get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# format: whatsapp:+14155238886  (sandbox) or your approved number
TWILIO_WHATSAPP_FROM=
